# Incognito Configuration
# Copy this file to .env and modify as needed

# Data directory (default: ~/.incognito)
# INCOGNITO_DATA_DIR=/home/user/.incognito

# Log level: debug, info, warning, error
# INCOGNITO_LOG_LEVEL=info

# Maximum emails sent per hour (to avoid SMTP rate limiting)
# INCOGNITO_RATE_LIMIT_PER_HOUR=10

# Session idle timeout in minutes
# INCOGNITO_SESSION_TIMEOUT_MINUTES=30

# GDPR response deadline in days
# INCOGNITO_GDPR_DEADLINE_DAYS=30

# Master password for automated follow-up via cron (optional)
# INCOGNITO_PASSWORD=

# Host and port for the web server
# INCOGNITO_HOST=127.0.0.1
# INCOGNITO_PORT=8080

# Extra CORS origins (comma-separated, for development)
# INCOGNITO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to true when running behind an HTTPS reverse proxy
# INCOGNITO_SECURE_COOKIES=false

# Push notifications (Ntfy, Gotify, or webhook URL)
# INCOGNITO_NOTIFY_URL=https://ntfy.sh/my-incognito-alerts

# Reverse proxy auth (Authentik, Authelia, Traefik ForwardAuth)
# Set to the header name your proxy sends (e.g. Remote-User, X-Forwarded-User)
# INCOGNITO_TRUSTED_PROXY_HEADER=Remote-User
